---
import { languages, siteUrl, type Lang, ui } from "../data/site";
import { localizePath } from "../data/games";

type Props = {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
};

const { lang, title, description, path = "/", image = "/og.svg", jsonLd } = Astro.props;
const absoluteUrl = new URL(path, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const labels = ui[lang];
const pathParts = path.split("/").filter(Boolean);
const slug = pathParts[0] === "tr" || pathParts[0] === "de" ? pathParts[1] : pathParts[0];
const switcherPaths = Object.keys(languages).map((code) => ({
  code: code as Lang,
  label: languages[code as Lang],
  path: localizePath(code as Lang, slug)
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absoluteUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" hreflang="en" href={new URL(localizePath("en", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="tr" href={new URL(localizePath("tr", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="de" href={new URL(localizePath("de", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath("en", slug), siteUrl).toString()} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0b0c0e;
        --bg-elev: #121316;
        --card: #141518;
        --card-hover: #191b1f;
        --ink: #f4f4f5;
        --muted: #9a9ba1;
        --faint: #6b6d74;
        --brand: #f97316;
        --brand-soft: #fb923c;
        --accent: #34d399;
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.14);
        --radius: 14px;
        --radius-sm: 10px;
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.4), 0 8px 24px rgba(0, 0, 0, 0.35);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      .site-shell {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.1rem 0;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.02rem;
        letter-spacing: -0.02em;
        color: var(--ink);
      }

      .brand-mark {
        display: grid;
        width: 2rem;
        height: 2rem;
        place-items: center;
        border-radius: 8px;
        background: linear-gradient(140deg, var(--brand), #ea580c);
        color: #fff;
        font-weight: 800;
      }

      .language-switcher {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.3rem;
        background: var(--bg-elev);
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.2rem;
      }

      .language-switcher a {
        border-radius: 999px;
        padding: 0.35rem 0.7rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        transition: color 140ms ease, background 140ms ease;
      }

      .language-switcher a:hover {
        color: var(--ink);
      }

      .language-switcher a[aria-current="page"] {
        background: rgba(255, 255, 255, 0.08);
        color: var(--ink);
      }

      .hero {
        display: grid;
        gap: 1rem;
        padding: 2.4rem 0 1.4rem;
      }

      .eyebrow {
        color: var(--brand-soft);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        letter-spacing: -0.03em;
        line-height: 1.05;
        color: var(--ink);
      }

      h1 {
        max-width: 16ch;
        font-size: clamp(2.6rem, 8vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
      }

      h2 {
        font-size: clamp(1.5rem, 4vw, 2.4rem);
        font-weight: 700;
      }

      h3 {
        font-size: 1.05rem;
        font-weight: 650;
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      .hero p {
        max-width: 44rem;
        margin: 0;
        font-size: 1.05rem;
      }

      .guide-hero {
        gap: 0.9rem;
        padding: 1.6rem 0 1.2rem;
      }

      .guide-hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 750;
        letter-spacing: -0.03em;
      }

      .guide-hero p {
        max-width: 46rem;
        font-size: 1.02rem;
      }

      .updated-note {
        margin: 0;
        font-size: 0.82rem;
        color: var(--faint);
      }

      .search-wrap {
        position: sticky;
        top: 0.6rem;
        z-index: 3;
        margin: 1rem 0 1.8rem;
      }

      .search-box {
        width: 100%;
        border: 1px solid var(--line-strong);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        background: var(--bg-elev);
        color: var(--ink);
        font-size: 0.98rem;
        font-weight: 500;
        outline: none;
        transition: border-color 140ms ease, box-shadow 140ms ease;
      }

      .search-box::placeholder {
        color: var(--faint);
      }

      .search-box:focus {
        border-color: rgba(249, 115, 22, 0.55);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
      }

      .section {
        padding: 1.4rem 0;
      }

      .section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-head h2 {
        font-size: 1.15rem;
        font-weight: 650;
        letter-spacing: -0.01em;
      }

      .section-head p {
        display: none;
        max-width: 34rem;
        margin: 0;
        font-size: 0.9rem;
        color: var(--faint);
      }

      .game-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.7rem;
      }

      .game-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 6.5rem;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 0.9rem;
        background: var(--card);
        text-decoration: none;
        transition:
          transform 160ms ease,
          background 160ms ease,
          border-color 160ms ease;
      }

      .game-card:hover,
      .game-card:focus-visible {
        border-color: var(--line-strong);
        background: var(--card-hover);
        transform: translateY(-2px);
      }

      .game-card strong {
        display: block;
        margin-bottom: 0.4rem;
        font-size: 0.98rem;
        font-weight: 600;
        line-height: 1.2;
        color: var(--ink);
      }

      .game-card span {
        color: var(--faint);
        font-size: 0.78rem;
        font-weight: 500;
      }

      .featured .game-card {
        min-height: 7.5rem;
        border-color: rgba(249, 115, 22, 0.25);
        background: linear-gradient(160deg, rgba(249, 115, 22, 0.1), var(--card) 60%);
      }

      .featured .game-card span {
        color: var(--brand-soft);
      }

      .guide-layout {
        display: grid;
        gap: 1rem;
        padding-bottom: 2rem;
      }

      .guide-card,
      .resource-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.4rem;
        background: var(--card);
      }

      .guide-card h2 {
        font-size: 1.1rem;
        font-weight: 650;
        margin-bottom: 0.9rem;
      }

      .guide-card ul {
        margin: 0;
        padding-left: 1.1rem;
      }

      .guide-card li {
        margin: 0.5rem 0;
        line-height: 1.65;
        color: var(--muted);
      }

      .guide-card li::marker {
        color: var(--brand-soft);
      }

      .guide-card p {
        margin: 0 0 0.9rem;
        color: var(--muted);
      }

      .guide-card p:last-child {
        margin-bottom: 0;
      }

      .resource-card h3 {
        margin-bottom: 0.8rem;
        color: var(--ink);
      }

      .resource-card ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.55rem;
      }

      .resource-card li {
        line-height: 1.5;
      }

      .resource-card a {
        color: var(--brand-soft);
        text-decoration: none;
        font-weight: 500;
      }

      .resource-card a:hover {
        text-decoration: underline;
      }

      .sponsor {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
        margin: 2.5rem 0 1rem;
        padding: 1.4rem;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--bg-elev);
      }

      .sponsor-body {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 15rem;
        flex: 1;
      }

      .sponsor-logo {
        flex-shrink: 0;
        width: 3rem;
        height: 3rem;
        border-radius: 12px;
        background: #0b0c0e;
        border: 1px solid var(--line);
      }

      .sponsor-title {
        display: block;
        font-size: 1rem;
        font-weight: 650;
        letter-spacing: -0.01em;
        color: var(--ink);
      }

      .sponsor-text {
        margin: 0.25rem 0 0;
        font-size: 0.88rem;
        line-height: 1.55;
        color: var(--muted);
      }

      .button {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        border-radius: 10px;
        padding: 0.7rem 1.1rem;
        background: var(--brand);
        color: #0b0c0e;
        font-weight: 650;
        font-size: 0.9rem;
        text-decoration: none;
        white-space: nowrap;
        transition: background 140ms ease;
      }

      .button:hover {
        background: var(--brand-soft);
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        width: fit-content;
        padding: 0.4rem 0.85rem 0.4rem 0.65rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--bg-elev);
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 550;
        text-decoration: none;
        transition: color 140ms ease, border-color 140ms ease;
      }

      .back-link:hover {
        color: var(--ink);
        border-color: var(--line-strong);
      }

      .footer {
        padding: 1.6rem 0 2.4rem;
        margin-top: 1rem;
        border-top: 1px solid var(--line);
        color: var(--faint);
        font-size: 0.85rem;
      }

      .hidden {
        display: none !important;
      }

      @media (min-width: 620px) {
        .game-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .section-head p {
          display: block;
        }
      }

      @media (min-width: 900px) {
        .hero {
          padding: 4rem 0 1.8rem;
        }

        .game-grid {
          grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .guide-layout {
          grid-template-columns: 1.15fr 0.85fr;
          align-items: start;
        }

        .guide-main {
          display: grid;
          gap: 1rem;
        }

        .guide-side {
          position: sticky;
          top: 1rem;
          display: grid;
          gap: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar" aria-label="Site navigation">
        <a class="brand" href={localizePath(lang)}>
          <span class="brand-mark">W</span>
          <span>{labels.siteName}</span>
        </a>
        <nav class="language-switcher" aria-label={labels.languages}>
          {
            switcherPaths.map((item) => (
              <a href={item.path} aria-current={item.code === lang ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <slot />
      <footer class="footer">© 2026 Win Board Games. {labels.tagline}</footer>
    </div>
  </body>
</html>
