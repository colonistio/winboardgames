---
import { languages, siteUrl, type Lang, ui } from "../data/site";
import { localizePath } from "../data/games";

type Props = {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
};

const { lang, title, description, path = "/", image = "/og.svg", jsonLd } = Astro.props;
const absoluteUrl = new URL(path, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const labels = ui[lang];
const pathParts = path.split("/").filter(Boolean);
const slug = pathParts[0] === "tr" || pathParts[0] === "de" ? pathParts[1] : pathParts[0];
const switcherPaths = Object.keys(languages).map((code) => ({
  code: code as Lang,
  label: languages[code as Lang],
  path: localizePath(code as Lang, slug)
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absoluteUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" hreflang="en" href={new URL(localizePath("en", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="tr" href={new URL(localizePath("tr", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="de" href={new URL(localizePath("de", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath("en", slug), siteUrl).toString()} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0b0c0e;
        --bg-elev: #121316;
        --card: #141518;
        --card-hover: #191b1f;
        --ink: #f4f4f5;
        --muted: #9a9ba1;
        --faint: #6b6d74;
        --brand: #f97316;
        --brand-soft: #fb923c;
        --accent: #34d399;
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.14);
        --radius: 14px;
        --radius-sm: 10px;
        --shadow: 0 1px 2px rgba(0, 0, 0, 0.4), 0 8px 24px rgba(0, 0, 0, 0.35);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      .site-shell {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.1rem 0;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.02rem;
        letter-spacing: -0.02em;
        color: var(--ink);
      }

      .brand-mark {
        display: grid;
        width: 2rem;
        height: 2rem;
        place-items: center;
        border-radius: 8px;
        background: linear-gradient(140deg, var(--brand), #ea580c);
        color: #fff;
        font-weight: 800;
      }

      .lang-dropdown {
        position: relative;
      }

      .lang-dropdown summary {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--bg-elev);
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 550;
        cursor: pointer;
        list-style: none;
        user-select: none;
        transition: color 140ms ease, border-color 140ms ease;
      }

      .lang-dropdown summary::-webkit-details-marker {
        display: none;
      }

      .lang-dropdown summary:hover {
        color: var(--ink);
        border-color: var(--line-strong);
      }

      .lang-dropdown[open] summary {
        color: var(--ink);
        border-color: var(--line-strong);
      }

      .lang-dropdown .chev {
        transition: transform 160ms ease;
      }

      .lang-dropdown[open] .chev {
        transform: rotate(180deg);
      }

      .lang-menu {
        position: absolute;
        right: 0;
        top: calc(100% + 0.4rem);
        z-index: 20;
        display: grid;
        min-width: 11rem;
        max-height: 60vh;
        overflow-y: auto;
        gap: 0.1rem;
        padding: 0.35rem;
        border: 1px solid var(--line-strong);
        border-radius: 12px;
        background: var(--card);
        box-shadow: var(--shadow);
      }

      .lang-menu a {
        padding: 0.5rem 0.7rem;
        border-radius: 8px;
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 500;
        text-decoration: none;
        transition: color 120ms ease, background 120ms ease;
      }

      .lang-menu a:hover {
        color: var(--ink);
        background: rgba(255, 255, 255, 0.06);
      }

      .lang-menu a[aria-current="page"] {
        color: var(--ink);
        background: rgba(249, 115, 22, 0.14);
      }

      .hero {
        display: grid;
        gap: 1rem;
        padding: 2.4rem 0 1.4rem;
      }

      .eyebrow {
        color: var(--brand-soft);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        letter-spacing: -0.03em;
        line-height: 1.05;
        color: var(--ink);
      }

      h1 {
        max-width: 16ch;
        font-size: clamp(2.6rem, 8vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
      }

      h2 {
        font-size: clamp(1.5rem, 4vw, 2.4rem);
        font-weight: 700;
      }

      h3 {
        font-size: 1.05rem;
        font-weight: 650;
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      .hero p {
        max-width: 44rem;
        margin: 0;
        font-size: 1.05rem;
      }

      .guide-hero {
        gap: 0.9rem;
        padding: 1.6rem 0 1.2rem;
      }

      .guide-hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 750;
        letter-spacing: -0.03em;
      }

      .guide-hero p {
        max-width: 46rem;
        font-size: 1.02rem;
      }

      .updated-note {
        margin: 0;
        font-size: 0.82rem;
        color: var(--faint);
      }

      .search-wrap {
        position: sticky;
        top: 0.6rem;
        z-index: 3;
        margin: 1rem 0 1.8rem;
      }

      .search-box {
        width: 100%;
        border: 1px solid var(--line-strong);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        background: var(--bg-elev);
        color: var(--ink);
        font-size: 0.98rem;
        font-weight: 500;
        outline: none;
        transition: border-color 140ms ease, box-shadow 140ms ease;
      }

      .search-box::placeholder {
        color: var(--faint);
      }

      .search-box:focus {
        border-color: rgba(249, 115, 22, 0.55);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
      }

      .section {
        padding: 1.4rem 0;
      }

      .section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-head h2 {
        font-size: 1.15rem;
        font-weight: 650;
        letter-spacing: -0.01em;
      }

      .section-head p {
        display: none;
        max-width: 34rem;
        margin: 0;
        font-size: 0.9rem;
        color: var(--faint);
      }

      .game-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.7rem;
      }

      .game-card {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--card);
        text-decoration: none;
        transition:
          transform 160ms ease,
          background 160ms ease,
          border-color 160ms ease;
      }

      a.game-card:hover,
      a.game-card:focus-visible {
        border-color: var(--line-strong);
        background: var(--card-hover);
        transform: translateY(-3px);
      }

      .card-thumb {
        position: relative;
        display: grid;
        place-items: center;
        aspect-ratio: 20 / 13;
        overflow: hidden;
        padding: 0.6rem;
        background:
          radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.06), transparent 70%),
          #0e0f12;
        border-bottom: 1px solid var(--line);
      }

      .card-thumb img {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        display: block;
        border-radius: 6px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.45);
        transition: transform 260ms ease;
      }

      .card-thumb.is-placeholder {
        padding: 0;
      }

      .card-thumb.is-placeholder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
        box-shadow: none;
      }

      a.game-card:hover .card-thumb img {
        transform: scale(1.04);
      }

      .card-body {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 0.7rem 0.8rem 0.85rem;
      }

      .game-card strong {
        display: block;
        font-size: 0.95rem;
        font-weight: 600;
        line-height: 1.25;
        color: var(--ink);
      }

      .card-sub {
        color: var(--faint);
        font-size: 0.78rem;
        font-weight: 500;
        line-height: 1.35;
      }

      .featured .game-card {
        border-color: rgba(249, 115, 22, 0.28);
      }

      .featured .card-sub {
        color: var(--brand-soft);
      }

      .guide-layout {
        display: grid;
        gap: 1rem;
        padding-bottom: 1rem;
      }

      .guide-main,
      .guide-side {
        display: grid;
        gap: 1rem;
        align-content: start;
      }

      .panel {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.35rem;
        background: var(--card);
      }

      .panel-head {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-bottom: 1.1rem;
      }

      .panel-head h2,
      .panel-head h3 {
        font-size: 1.02rem;
        font-weight: 650;
        letter-spacing: -0.01em;
      }

      .panel-icon {
        display: grid;
        place-items: center;
        width: 2rem;
        height: 2rem;
        flex-shrink: 0;
        border-radius: 8px;
        background: rgba(249, 115, 22, 0.14);
        color: var(--brand-soft);
      }

      .tip-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.7rem;
      }

      .tip-list li {
        display: grid;
        grid-template-columns: 2rem 1fr;
        gap: 0.9rem;
        align-items: start;
        line-height: 1.55;
        color: var(--ink);
      }

      .tip-list .tick {
        justify-self: center;
        margin-top: 0.15rem;
        color: var(--accent);
      }

      .step-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0;
      }

      .step-list li {
        position: relative;
        display: grid;
        grid-template-columns: 2rem 1fr;
        gap: 0.9rem;
        padding-bottom: 1.4rem;
      }

      .step-list li:last-child {
        padding-bottom: 0;
      }

      .step-list li::before {
        content: "";
        position: absolute;
        left: 1rem;
        top: 2.2rem;
        bottom: 0.2rem;
        width: 1px;
        background: linear-gradient(var(--line-strong), transparent);
      }

      .step-list li:last-child::before {
        display: none;
      }

      .step-num {
        display: grid;
        place-items: center;
        flex-shrink: 0;
        width: 2rem;
        height: 2rem;
        border-radius: 9px;
        background: linear-gradient(150deg, rgba(249, 115, 22, 0.22), rgba(249, 115, 22, 0.08));
        border: 1px solid rgba(249, 115, 22, 0.35);
        color: var(--brand-soft);
        font-size: 0.85rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
      }

      .step-list p {
        margin: 0.2rem 0 0;
        color: var(--muted);
        line-height: 1.65;
      }

      .link-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.5rem;
      }

      .link-list a {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        padding: 0.7rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        color: var(--ink);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: border-color 140ms ease, background 140ms ease;
      }

      .link-list a:hover {
        border-color: var(--line-strong);
        background: rgba(255, 255, 255, 0.04);
      }

      .link-list svg {
        flex-shrink: 0;
        color: var(--brand-soft);
      }

      .chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: rgba(255, 255, 255, 0.04);
        color: var(--ink);
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 140ms ease, background 140ms ease;
      }

      a.chip:hover {
        border-color: rgba(249, 115, 22, 0.5);
        background: rgba(249, 115, 22, 0.12);
      }

      .chip-static {
        color: var(--faint);
      }

      .sponsor {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
        margin: 2.5rem 0 1rem;
        padding: 1.4rem;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--bg-elev);
      }

      .sponsor-body {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 15rem;
        flex: 1;
      }

      .sponsor-logo {
        flex-shrink: 0;
        width: 3.25rem;
        height: 3.25rem;
      }

      .sponsor-title {
        display: block;
        font-size: 1rem;
        font-weight: 650;
        letter-spacing: -0.01em;
        color: var(--ink);
      }

      .sponsor-text {
        margin: 0.25rem 0 0;
        font-size: 0.88rem;
        line-height: 1.55;
        color: var(--muted);
      }

      .button {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        border-radius: 10px;
        padding: 0.7rem 1.1rem;
        background: var(--brand);
        color: #0b0c0e;
        font-weight: 650;
        font-size: 0.9rem;
        text-decoration: none;
        white-space: nowrap;
        transition: background 140ms ease;
      }

      .button:hover {
        background: var(--brand-soft);
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        width: fit-content;
        padding: 0.4rem 0.85rem 0.4rem 0.65rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--bg-elev);
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 550;
        text-decoration: none;
        transition: color 140ms ease, border-color 140ms ease;
      }

      .back-link:hover {
        color: var(--ink);
        border-color: var(--line-strong);
      }

      .footer {
        padding: 1.6rem 0 2.4rem;
        margin-top: 1rem;
        border-top: 1px solid var(--line);
        color: var(--faint);
        font-size: 0.85rem;
      }

      .hidden {
        display: none !important;
      }

      @media (min-width: 620px) {
        .game-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .section-head p {
          display: block;
        }
      }

      @media (min-width: 900px) {
        .hero {
          padding: 4rem 0 1.8rem;
        }

        .game-grid {
          grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .guide-layout {
          grid-template-columns: 1.15fr 0.85fr;
          align-items: start;
        }

        .guide-side {
          position: sticky;
          top: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar" aria-label="Site navigation">
        <a class="brand" href={localizePath(lang)}>
          <span class="brand-mark">W</span>
          <span>{labels.siteName}</span>
        </a>
        <details class="lang-dropdown" aria-label={labels.languages}>
          <summary>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
            </svg>
            <span>{languages[lang]}</span>
            <svg class="chev" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>
          <div class="lang-menu">
            {
              switcherPaths.map((item) => (
                <a href={item.path} aria-current={item.code === lang ? "page" : undefined}>
                  {item.label}
                </a>
              ))
            }
          </div>
        </details>
      </header>
      <slot />
      <footer class="footer">© 2026 Win Board Games. {labels.tagline}</footer>
    </div>
    <script>
      const dropdown = document.querySelector(".lang-dropdown");
      if (dropdown instanceof HTMLDetailsElement) {
        document.addEventListener("click", (event) => {
          if (dropdown.open && !dropdown.contains(event.target as Node)) {
            dropdown.open = false;
          }
        });
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") dropdown.open = false;
        });
      }
    </script>
  </body>
</html>
