---
import { languages, siteUrl, type Lang, ui } from "../data/site";
import { localizePath } from "../data/games";

type Props = {
  lang: Lang;
  title: string;
  description: string;
  path?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
};

const { lang, title, description, path = "/", image = "/og.svg", jsonLd } = Astro.props;
const absoluteUrl = new URL(path, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const labels = ui[lang];
const pathParts = path.split("/").filter(Boolean);
const slug = pathParts[0] === "tr" || pathParts[0] === "de" ? pathParts[1] : pathParts[0];
const switcherPaths = Object.keys(languages).map((code) => ({
  code: code as Lang,
  label: languages[code as Lang],
  path: localizePath(code as Lang, slug)
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absoluteUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" hreflang="en" href={new URL(localizePath("en", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="tr" href={new URL(localizePath("tr", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="de" href={new URL(localizePath("de", slug), siteUrl).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath("en", slug), siteUrl).toString()} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #fff7ed;
        --bg-strong: #ffedd5;
        --card: #ffffff;
        --ink: #1f2937;
        --muted: #6b7280;
        --brand: #f97316;
        --brand-dark: #c2410c;
        --green: #16a34a;
        --line: #fed7aa;
        --shadow: 0 18px 45px rgba(154, 52, 18, 0.14);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(251, 146, 60, 0.28), transparent 34rem),
          linear-gradient(180deg, var(--bg), #ffffff 48rem);
        color: var(--ink);
      }

      a {
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      .site-shell {
        width: min(1180px, calc(100% - 1.5rem));
        margin: 0 auto;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 0;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
        font-weight: 900;
        letter-spacing: -0.04em;
      }

      .brand-mark {
        display: grid;
        width: 2.4rem;
        height: 2.4rem;
        place-items: center;
        border-radius: 0.8rem;
        background: var(--ink);
        color: #fff;
        box-shadow: var(--shadow);
      }

      .language-switcher {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.35rem;
      }

      .language-switcher a {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.4rem 0.65rem;
        background: rgba(255, 255, 255, 0.72);
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 800;
        text-decoration: none;
      }

      .language-switcher a[aria-current="page"] {
        background: var(--ink);
        color: #fff;
        border-color: var(--ink);
      }

      .hero {
        display: grid;
        gap: 1rem;
        padding: 2rem 0 1.2rem;
      }

      .eyebrow {
        color: var(--brand-dark);
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        letter-spacing: -0.055em;
        line-height: 0.95;
      }

      h1 {
        max-width: 12ch;
        font-size: clamp(3.1rem, 15vw, 8.5rem);
      }

      h2 {
        font-size: clamp(1.9rem, 7vw, 3.8rem);
      }

      h3 {
        font-size: 1.3rem;
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      .hero p {
        max-width: 42rem;
        margin: 0;
        font-size: 1.08rem;
      }

      .search-wrap {
        position: sticky;
        top: 0.5rem;
        z-index: 3;
        margin: 1rem 0 1.4rem;
      }

      .search-box {
        width: 100%;
        border: 2px solid rgba(249, 115, 22, 0.22);
        border-radius: 1.25rem;
        padding: 1rem 1.1rem;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: var(--shadow);
        color: var(--ink);
        font-size: 1rem;
        font-weight: 700;
        outline: none;
      }

      .search-box:focus {
        border-color: var(--brand);
      }

      .section {
        padding: 1.3rem 0;
      }

      .section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.8rem;
      }

      .section-head p {
        display: none;
        max-width: 34rem;
        margin: 0;
      }

      .game-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
      }

      .game-card {
        min-height: 8.2rem;
        border: 1px solid rgba(254, 215, 170, 0.95);
        border-radius: 1.2rem;
        padding: 0.9rem;
        background:
          linear-gradient(140deg, rgba(255, 255, 255, 0.95), rgba(255, 237, 213, 0.72)),
          var(--card);
        box-shadow: 0 10px 25px rgba(154, 52, 18, 0.08);
        text-decoration: none;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease;
      }

      .game-card:hover,
      .game-card:focus-visible {
        border-color: var(--brand);
        box-shadow: var(--shadow);
        transform: translateY(-2px);
      }

      .game-card strong {
        display: block;
        margin-bottom: 0.45rem;
        font-size: 1rem;
        line-height: 1.08;
      }

      .game-card span {
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
      }

      .featured .game-card {
        min-height: 10rem;
        background:
          radial-gradient(circle at top right, rgba(249, 115, 22, 0.28), transparent 8rem),
          #fff;
      }

      .guide-layout {
        display: grid;
        gap: 1rem;
        padding-bottom: 2rem;
      }

      .guide-card,
      .sponsor,
      .resource-card {
        border: 1px solid var(--line);
        border-radius: 1.4rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 10px 25px rgba(154, 52, 18, 0.08);
      }

      .guide-card ul {
        margin: 0;
        padding-left: 1.2rem;
      }

      .guide-card li {
        margin: 0.55rem 0;
        line-height: 1.6;
      }

      .guide-card p:first-child {
        margin-top: 0;
      }

      .sponsor {
        display: grid;
        gap: 0.75rem;
        margin: 2rem 0;
        background:
          radial-gradient(circle at top right, rgba(22, 163, 74, 0.18), transparent 12rem),
          #f0fdf4;
        border-color: #bbf7d0;
      }

      .sponsor strong {
        font-size: 1.2rem;
        letter-spacing: -0.03em;
      }

      .button {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.75rem 1rem;
        background: var(--green);
        color: #fff;
        font-weight: 900;
        text-decoration: none;
      }

      .footer {
        padding: 1rem 0 2rem;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .hidden {
        display: none !important;
      }

      @media (min-width: 620px) {
        .game-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .section-head p {
          display: block;
        }
      }

      @media (min-width: 900px) {
        .site-shell {
          width: min(1180px, calc(100% - 3rem));
        }

        .hero {
          padding: 4rem 0 1.6rem;
        }

        .game-grid {
          grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .guide-layout {
          grid-template-columns: 1.2fr 0.8fr;
          align-items: start;
        }

        .guide-main {
          display: grid;
          gap: 1rem;
        }

        .guide-side {
          position: sticky;
          top: 1rem;
          display: grid;
          gap: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar" aria-label="Site navigation">
        <a class="brand" href={localizePath(lang)}>
          <span class="brand-mark">W</span>
          <span>{labels.siteName}</span>
        </a>
        <nav class="language-switcher" aria-label={labels.languages}>
          {
            switcherPaths.map((item) => (
              <a href={item.path} aria-current={item.code === lang ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <slot />
      <footer class="footer">© 2026 Win Board Games. {labels.tagline}</footer>
    </div>
  </body>
</html>
