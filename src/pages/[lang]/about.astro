---
import AboutPage from "../../components/AboutPage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localizePath } from "../../data/games";
import { aboutContent, nonDefaultLangs, repoUrl, type Lang, siteUrl } from "../../data/site";

export function getStaticPaths() {
  return nonDefaultLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const content = aboutContent[lang];
const path = localizePath(lang, "about");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: content.title,
  description: content.metaDescription,
  url: new URL(path, siteUrl).toString(),
  inLanguage: lang,
  isPartOf: {
    "@type": "WebSite",
    name: "Win Board Games",
    url: siteUrl
  },
  publisher: {
    "@type": "Organization",
    name: "Win Board Games",
    url: siteUrl
  },
  sameAs: [repoUrl]
};
---

<BaseLayout lang={lang} title={content.title} description={content.metaDescription} path={path} jsonLd={jsonLd}>
  <AboutPage lang={lang} />
</BaseLayout>
