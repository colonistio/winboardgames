---
import HomePage from "../../components/HomePage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories, guides, localizePath } from "../../data/games";
import { type Lang, siteUrl, ui } from "../../data/site";

export function getStaticPaths() {
  return [{ params: { lang: "tr" } }, { params: { lang: "de" } }];
}

const lang = Astro.params.lang as Lang;
const labels = ui[lang];
const title = `${labels.siteName}: ${labels.allGames}`;
const description = labels.pageDescription;
const path = localizePath(lang);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: labels.siteName,
  url: new URL(path, siteUrl).toString(),
  description,
  inLanguage: lang,
  about: categories.map((category) => category.name[lang]),
  mainEntity: guides.map((guide) => ({
    "@type": "Article",
    headline: guide.metaTitle[lang],
    url: new URL(localizePath(lang, guide.slug), siteUrl).toString()
  }))
};
---

<BaseLayout lang={lang} title={title} description={description} path={path} jsonLd={jsonLd}>
  <HomePage lang={lang} />
</BaseLayout>
