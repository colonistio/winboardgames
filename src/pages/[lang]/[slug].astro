---
import GameGuidePage from "../../components/GameGuidePage.astro";
import { guides, listingBySlug, localizePath } from "../../data/games";
import { nonDefaultLangs, type Lang, siteUrl, ui } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return nonDefaultLangs.flatMap((lang) =>
    guides.map((guide) => ({
      params: { lang, slug: guide.slug },
      props: { guide, lang }
    }))
  );
}

const { guide, lang } = Astro.props as { guide: (typeof guides)[number]; lang: Lang };
const path = localizePath(lang, guide.slug);
const listing = listingBySlug[guide.slug];
const pageUrl = new URL(path, siteUrl).toString();
const homeUrl = new URL(localizePath(lang), siteUrl).toString();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: ui[lang].home, item: homeUrl },
      { "@type": "ListItem", position: 2, name: guide.title, item: pageUrl }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: guide.metaTitle[lang],
    description: guide.metaDescription[lang],
    datePublished: guide.updated,
    dateModified: guide.updated,
    inLanguage: lang,
    mainEntityOfPage: pageUrl,
    image: listing?.image ? new URL(listing.image, siteUrl).toString() : new URL("/og.svg", siteUrl).toString(),
    author: {
      "@type": "Organization",
      name: "Win Board Games",
      url: siteUrl
    },
    publisher: {
      "@type": "Organization",
      name: "Win Board Games",
      url: siteUrl
    }
  }
];
---

<BaseLayout
  lang={lang}
  title={guide.metaTitle[lang]}
  description={guide.metaDescription[lang]}
  path={path}
  image={listing?.image}
  jsonLd={jsonLd}
>
  <GameGuidePage lang={lang} guide={guide} />
</BaseLayout>
