---
import AboutPage from "../components/AboutPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { aboutContent, repoUrl, siteUrl } from "../data/site";

const lang = "en";
const content = aboutContent[lang];
const path = "/about";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: content.title,
  description: content.metaDescription,
  url: new URL(path, siteUrl).toString(),
  inLanguage: lang,
  isPartOf: {
    "@type": "WebSite",
    name: "Win Board Games",
    url: siteUrl
  },
  publisher: {
    "@type": "Organization",
    name: "Win Board Games",
    url: siteUrl
  },
  sameAs: [repoUrl]
};
---

<BaseLayout lang={lang} title={content.title} description={content.metaDescription} path={path} jsonLd={jsonLd}>
  <AboutPage lang={lang} />
</BaseLayout>
