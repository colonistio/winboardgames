---
import HomePage from "../components/HomePage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { categories, guides } from "../data/games";
import { siteUrl, ui } from "../data/site";

const lang = "en";
const labels = ui[lang];
const title = `${labels.siteName}: Board Game Strategy Guides`;
const description = labels.pageDescription;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: labels.siteName,
  url: siteUrl,
  description,
  inLanguage: lang,
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  },
  about: categories.map((category) => category.name[lang]),
  mainEntity: guides.map((guide) => ({
    "@type": "Article",
    headline: guide.metaTitle[lang],
    url: `${siteUrl}/${guide.slug}`
  }))
};
---

<BaseLayout lang={lang} title={title} description={description} path="/" jsonLd={jsonLd}>
  <HomePage lang={lang} />
</BaseLayout>
