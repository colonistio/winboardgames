---
import FooterSponsor from "./FooterSponsor.astro";
import { localizePath } from "../data/games";
import { aboutContent, repoUrl, type Lang, ui } from "../data/site";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
const content = aboutContent[lang];
const labels = ui[lang];
---

<article class="about-page">
  <a class="back-link" href={localizePath(lang)}>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M19 12H5M12 19l-7-7 7-7" />
    </svg>
    {labels.home}
  </a>

  <header class="about-hero">
    <h1>{content.title}</h1>
    <p>{content.intro}</p>
  </header>

  <section class="panel">
    <div class="panel-head">
      <span class="panel-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20V10M18 20V4M6 20v-4" />
        </svg>
      </span>
      <h2>{content.missionTitle}</h2>
    </div>
    <p>{content.mission}</p>
  </section>

  <section class="panel">
    <div class="panel-head">
      <span class="panel-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
        </svg>
      </span>
      <h2>{content.contributeTitle}</h2>
    </div>
    <p>{content.contribute}</p>
    <p>
      <a class="about-repo-link" href={repoUrl} target="_blank" rel="noopener noreferrer">{content.contributeCta}</a>
    </p>
  </section>
</article>

<FooterSponsor lang={lang} />

<style>
  .about-page {
    display: grid;
    gap: 1rem;
    padding-bottom: 0.5rem;
  }

  .about-hero h1 {
    margin: 0.4rem 0 0.6rem;
    font-size: clamp(1.5rem, 4vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .about-hero p {
    margin: 0;
    max-width: 42rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .about-page .panel p {
    margin: 0;
    line-height: 1.6;
    color: var(--ink);
  }

  .about-page .panel p + p {
    margin-top: 1rem;
  }

  .about-repo-link {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-sm);
    color: var(--ink);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .about-repo-link:hover {
    border-color: var(--brand);
    background: rgba(249, 115, 22, 0.08);
  }
</style>
